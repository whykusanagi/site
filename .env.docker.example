# Celeste Widget Configuration for Docker Container
# Copy this file to .env.docker and fill in your actual credentials
# DO NOT commit .env.docker to git - it contains secrets!

# Base URL for your AI agent endpoint
CELESTE_AGENT_BASE_URL=https://your-agent-endpoint.example.com

# Agent ID (UUID format)
CELESTE_AGENT_ID=00000000-0000-0000-0000-000000000000

# Agent API Key (KEEP SECRET! Never commit this value)
CELESTE_AGENT_KEY=your-secret-api-key-here

# NOTE: These credentials are only used by the backend proxy server
# They should NEVER be exposed to client-side code
# The /api/chat endpoint handles authentication securely
